{
  "name": "destinx",
  "version": "0.1.0",
  "description": "AI Travel Agent — WhatsApp-first, browser-automation-powered, memory-driven",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "npx drizzle-kit push --force || echo 'drizzle-kit push failed, continuing...'; node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "travel",
    "ai",
    "whatsapp",
    "booking"
  ],
  "license": "PRIVATE",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@browserbasehq/sdk": "^2.9.0",
    "@browserbasehq/stagehand": "^3.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "twilio": "^5.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
