# Server
PORT=3000
APP_URL=https://your-app.railway.app

# Database
DATABASE_URL=postgresql://user:pass@host:5432/travel_agent

# Redis
REDIS_URL=redis://default:pass@host:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886

# Browser automation (set to 'true' to enable Browserbase booking — requires Enterprise for stealth)
ENABLE_BROWSER_AUTOMATION=false
BROWSERBASE_API_KEY=bb_...
BROWSERBASE_PROJECT_ID=proj_...

# Search APIs
GOOGLE_MAPS_API_KEY=AIza...
DUFFEL_API_KEY=duffel_test_...
BRAVE_SEARCH_API_KEY=BSA...

# CAPTCHA fallback (optional)
TWO_CAPTCHA_API_KEY=...

# Embeddings (optional)
VOYAGE_API_KEY=pa-...

# OpenAI (REQUIRED for Stagehand browser automation — powers act/observe/extract)
OPENAI_API_KEY=sk-...

# Weather (optional)
OPENWEATHERMAP_API_KEY=...

# Stripe Payments (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SERVICE_FEE_CENTS=1500
# Set to "true" to force Stripe checkout even with a Duffel test key
FORCE_STRIPE_FLOW=false

# Events (optional)
TICKETMASTER_API_KEY=...

# Health check (optional — protects /health/detailed)
HEALTH_CHECK_API_KEY=...

# File Storage (optional)
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...
CLOUDFLARE_R2_BUCKET=travel-agent
CLOUDFLARE_R2_ENDPOINT=https://...r2.cloudflarestorage.com
